# ── Required ──────────────────────────────────────────────────────────────────
# At least one LLM provider key is required to run the agent.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional — additional model providers ─────────────────────────────────────
# Include to enable GPT-4o or DeepSeek in multi-model evaluation.
# The API server starts without these and simply marks those models as unavailable.
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Optional — web search tool ────────────────────────────────────────────────
# Required only if you want the agent to search the web.
# Free tier: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Optional — LangSmith tracing ─────────────────────────────────────────────
# Enables full trace visualization in the LangSmith UI.
# Free tier: https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=document-intelligence-agent
